class Solution {
public:
    int maxOperations(vector<int>& nums, int k) {
        int answer = 0;
        sort(nums.begin(), nums.end());
        int firstPtr = 0;
        int lastPtr = nums.size() - 1;
        while(firstPtr < lastPtr){
            int sum = nums[firstPtr] + nums[lastPtr];
            if(sum < k){
                firstPtr ++;
            }
            else if(sum > k){
                lastPtr --;
            }
            else{
                answer ++;
                firstPtr ++;
                lastPtr --;
            }
        }
        return answer;
        
    }
};
