class Solution {
public:
    long long maxTotalValue(vector<int>& nums, int k) {
        long long answer = 0;
        sort(nums.begin(), nums.end());
        int maxVal = nums[nums.size()-  1];
        int minVal = nums[0];

        answer = 1LL * k * (maxVal - minVal);

        return answer;
        
    }
};
